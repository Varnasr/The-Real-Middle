  - type: data
    title: World Inequality Database (WID)
    authors:
      - name: World Inequality Lab
    url: https://wid.world
  - type: data
    title: Periodic Labour Force Survey (PLFS) 2023-24
    authors:
      - name: Ministry of Statistics and Programme Implementation, Government of India
    url: https://mospi.gov.in
  - type: data
    title: Economic Survey 2024-25
    authors:
      - name: Ministry of Finance, Government of India
    url: https://indiabudget.gov.in
